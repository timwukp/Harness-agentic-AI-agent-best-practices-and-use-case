{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "uitestagent",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "uitestagent",
    "use-case": "ui-testing"
  },
  "runtimes": [
    {
      "name": "uitestagent",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/ui-test-agent/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "protocol": "HTTP",
      "filesystemConfigurations": [
        {
          "sessionStorage": {
            "mountPath": "/mnt/reports"
          }
        }
      ]
    }
  ],
  "memories": [
    {
      "name": "uitestagentMemory",
      "eventExpiryDuration": 30,
      "strategies": [
        {
          "type": "SEMANTIC",
          "namespaceTemplates": [
            "/users/{actorId}/facts"
          ]
        },
        {
          "type": "USER_PREFERENCE",
          "namespaceTemplates": [
            "/users/{actorId}/preferences"
          ]
        },
        {
          "type": "SUMMARIZATION",
          "namespaceTemplates": [
            "/summaries/{actorId}/{sessionId}"
          ]
        },
        {
          "type": "EPISODIC",
          "namespaceTemplates": [
            "/episodes/{actorId}/{sessionId}"
          ],
          "reflectionNamespaceTemplates": [
            "/episodes/{actorId}"
          ]
        }
      ]
    }
  ],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "httpGateways": []
}